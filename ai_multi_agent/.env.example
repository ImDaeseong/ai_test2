# OpenRouter API key from https://openrouter.ai/keys
# Place this file in the ai_multi_agent/ folder or the parent workspace folder.
OPENROUTER_API_KEY=sk-or-...

# Optional OpenAI image generation key for MV image creation.
# If this is missing, the MV page can still show/copy prompts but cannot generate images.
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1536x1024

# Model override. See https://openrouter.ai/models
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_MODEL=openai/gpt-4o

# Optional project roots. Relative paths are resolved from the workspace root,
# which is the parent folder of ai_multi_agent.
# Defaults:
# HERMES_ROOT=ai_img_video_prompt
# STORY_ROOT=ai_story
# SCENARIO_ROOT=ai_Scenario
# ANIME_ROOT=ai_anime
